rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Доступ разрешён только пользователям из whitelist.
    // ВАЖНО: замени ВСТАВЬ_UID_ВЛАДЕЛЬЦА на реальный UID
    // (Firebase Console → Authentication → Users → колонка User UID).
    // Для нескольких сотрудников — добавь их UID в этот список через запятую.
    function isAllowed() {
      return request.auth != null
        && request.auth.uid in ['XqJUnm47gIPjQPJfKUTvgWnS0un2'];
    }

    // Строка в пределах лимита. Отсутствующее поле подставляется как ''.
    function str(value, maxLen) {
      return value is string && value.size() <= maxLen;
    }

    // Блок контактов родителя. phones — список номеров (до 4).
    // Поле phone оставлено для документов, созданных до появления списка.
    function validParent(p) {
      return p is map
        && str(p.get('name', ''), 100)
        && str(p.get('phone', ''), 50)
        && p.get('phones', []) is list
        && p.get('phones', []).size() <= 4
        && str(p.get('instagram', ''), 100)
        && str(p.get('telegram', ''), 100);
    }

    // --- clients ---
    match /clients/{id} {
      allow read, delete: if isAllowed();
      allow create, update: if isAllowed()
        && request.resource.data.childName is string
        && request.resource.data.childName.size() > 0
        && request.resource.data.childName.size() <= 100
        && str(request.resource.data.get('birthDate', ''), 10)
        && request.resource.data.get('gender', '') in ['male', 'female', '']
        && str(request.resource.data.get('childContacts', ''), 200)
        && validParent(request.resource.data.get('mother', {}))
        && validParent(request.resource.data.get('father', {}))
        && request.resource.data.get('source', '') in ['instagram_ads', 'telegram_ads', 'recommendation', 'other', '']
        && str(request.resource.data.get('sourceNote', ''), 200)
        && str(request.resource.data.get('allergies', ''), 500)
        && str(request.resource.data.get('notes', ''), 1000);
    }

    // --- payments ---
    match /payments/{id} {
      allow read, delete: if isAllowed();
      allow create, update: if isAllowed()
        && request.resource.data.amount is number
        && request.resource.data.amount >= 0
        && request.resource.data.type in ['income', 'session']
        && request.resource.data.clientId is string;
    }

    // --- expenses ---
    match /expenses/{id} {
      allow read, delete: if isAllowed();
      allow create, update: if isAllowed()
        && request.resource.data.amount is number
        && request.resource.data.amount >= 0
        && request.resource.data.category is string;
    }

    // Всё остальное — запрещено.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
